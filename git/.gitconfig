[init]
	defaultBranch = main
[user]
	name = Denis Castillón
	email = orangeneko158@outlook.com
[diff]
	tool = meld
[difftool]
	prompt = false
[core]
	editor = nvim
[alias]
	graph = log --oneline --graph --decorate --all

# ========== Configurar Delta ==========
[core]
    pager = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    keep-plus-minus-markers = true
    navigate = true        # Usar n y N para moverse entre secciones del diff
    ; side-by-side = true  # Desactivado para activarse con un alias

; [merge]
;     conflictstyle = diff3
;
; [diff]
;     colorMoved = default
